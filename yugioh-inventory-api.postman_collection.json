    {
      "name": "📦 Inventario de Cartas",
      "item": [
        {
          "name": "Registrar carta — por nombre",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dark Magician\",\n  \"condition\": \"near_mint\",\n  \"quantity\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/cards",
              "host": ["{{baseUrl}}"],
              "path": ["cards"]
            },
            "description": "Registra una carta buscándola por nombre exacto en la API de YGOProdeck.\n\nSi la carta ya existe en el inventario, incrementa la cantidad.\n\n**condition válidos:** `new`, `near_mint`, `lightly_played`, `moderately_played`, `heavily_played`, `damaged`"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Status 201 o 200', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Response success = true', () => {",
                  "  pm.expect(json.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Card tiene id de Firestore', () => {",
                  "  pm.expect(json.data.id).to.be.a('string');",
                  "});",
                  "",
                  "// Guardar el ID de Firestore como variable de colección",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('cardId', json.data.id);",
                  "  console.log('cardId guardado:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
