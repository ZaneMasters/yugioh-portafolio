        {
          "name": "Buscar cartas por nombre",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/external/cards?name=Dark Magician",
              "host": ["{{baseUrl}}"],
              "path": ["external", "cards"],
              "query": [
                {
                  "key": "name",
                  "value": "Dark Magician",
                  "description": "Nombre parcial o completo de la carta"
                }
              ]
            },
            "description": "Busca cartas en la API externa de YGOProdeck usando el parámetro `fname` (búsqueda parcial).\n\nLa respuesta queda cacheada en memoria por el TTL configurado (default 5 min)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response tiene estructura correcta', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data).to.be.an('array');",
                  "  pm.expect(json.count).to.be.a('number');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
