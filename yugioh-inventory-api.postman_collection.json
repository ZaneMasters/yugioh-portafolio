{
  "info": {
    "name": "Yu-Gi-Oh! Inventory API",
    "_postman_id": "yugioh-inventory-api-v1",
    "description": "Colección completa para probar la API REST de inventario de cartas Yu-Gi-Oh!.\n\n**Base URL:** `http://localhost:3000/api/v1`\n\n**Variables de entorno recomendadas:**\n- `baseUrl` → `http://localhost:3000/api/v1`\n- `cardId` → ID de Firestore de una carta creada",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "cardId",
      "value": "",
      "type": "string",
      "description": "ID de Firestore de una carta. Se puede setear automáticamente con el script del POST /cards."
    }
  ],
  "item": [
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["health"]
            },
            "description": "Verifica que el servidor esté activo."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has status ok', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
