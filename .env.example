# =============================================
# Yu-Gi-Oh! Inventory API — Variables de entorno
# =============================================
# Copia este archivo como .env y completa los valores

# ---------------------------
# Servidor
# ---------------------------
PORT=3000
NODE_ENV=development

# ---------------------------
# Firebase Admin SDK
# ---------------------------
# Opción 1: Ruta al archivo de credenciales JSON descargado de Firebase Console
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Opción 2 (alternativa para producción / CI-CD): credenciales como string JSON en base64
# FIREBASE_CREDENTIALS_BASE64=<base64_encoded_service_account_json>

# ID del proyecto Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id

# ---------------------------
# API Externa — YGOProdeck
# ---------------------------
YGO_API_BASE_URL=https://db.ygoprodeck.com/api/v7

# ---------------------------
# Cache en memoria
# ---------------------------
# TTL en segundos para resultados de la API externa (default: 300 = 5 min)
CACHE_TTL_SECONDS=300
# Máximo de entradas en la cache LRU
CACHE_MAX_SIZE=200

# ---------------------------
# Logging
# ---------------------------
# Niveles: error | warn | info | http | debug
LOG_LEVEL=info
